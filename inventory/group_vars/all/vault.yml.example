# This is a TEMPLATE only -- showing what to put inside the real,
# ansible-vault-encrypted file. Do not commit this content unencrypted.
#
# Create the real file with:
#   ansible-vault create inventory/group_vars/all/vault.yml
#
# Ansible auto-loads any group_vars/all/*.yml file (encrypted or not), so
# once vault.yml exists and is encrypted, these vars are available to every
# playbook automatically -- no vars_files: needed.
#
# ---
# vault_become_password: "REPLACE_ME"
# vault_mysql_semaphore_password: "REPLACE_ME"
# vault_ansible_ssh_key_passphrase: "REPLACE_ME"
